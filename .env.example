# Auth.js v5 Environment Variables
# Rename from NEXTAUTH_* to AUTH_* for Auth.js v5

# Generate with: openssl rand -base64 32
# Minimum recommended length: 32 bytes (256 bits)
# DO NOT use this placeholder in production!
AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# Local development URL. Change to your production domain in production.
AUTH_URL=http://localhost:3000

# Google OAuth — get from Google Cloud Console
# Authorized redirect URI: ${AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Legacy support (optional, for backward compatibility)
NEXTAUTH_SECRET=${AUTH_SECRET}
NEXTAUTH_URL=${AUTH_URL}

# Convex
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud/api

# ═══════════════════════════════════════════════════════════════
# MICROSOFT 365 INTEGRATION (Outlook Calendar + SharePoint)
# Required for: employee database sync from SharePoint, leave
# event synchronization to Outlook Calendar
#
# Setup:
# 1. Create App Registration in Azure AD (Microsoft Entra ID)
#    → https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
# 2. Set supported account types: "Single tenant"
# 3. Add redirect URIs (all 4):
#    - https://yourdomain.com/api/calendar/outlook/callback
#    - https://yourdomain.com/api/sharepoint/callback
#    - http://localhost:3000/api/calendar/outlook/callback
#    - http://localhost:3000/api/sharepoint/callback
# 4. Add API Permissions (Microsoft Graph, delegated):
#    - User.Read (no admin consent needed)
#    - Calendars.ReadWrite (admin consent REQUIRED)
#    - Sites.Read.All (admin consent REQUIRED)
#    - offline_access (no admin consent needed)
# 5. Grant admin consent for the organization
# 6. Create Client Secret (Certificates & secrets → New)
#    → Set expiry to 24 months, copy the VALUE (not Secret ID)
# 7. Configure SharePoint List for employee sync with columns:
#    - Title (required), Email (required, unique key),
#    - Category (required: staff/contractor),
#    - Department, JobTitle, Status (optional)
# ═══════════════════════════════════════════════════════════════

# Application (client) ID from Azure AD App Registration
# Used on both frontend and backend
# Find it: Azure Portal → Entra ID → App Registrations → Overview
MICROSOFT_CLIENT_ID=your-azure-ad-client-id-here

# Same as above, exposed to frontend for building OAuth URLs
# Must have NEXT_PUBLIC_ prefix for Next.js client-side access
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=your-azure-ad-client-id-here

# Client Secret from Azure AD (Certificates & secrets → Value)
# ⚠️ IMPORTANT: This value is shown ONLY ONCE at creation.
# Set a calendar reminder to rotate before the 24-month expiry.
MICROSOFT_CLIENT_SECRET=your-client-secret-value-here

# Directory (tenant) ID from Azure AD
# Identifies ADB's Azure AD tenant for single-tenant auth
# Find it: Azure Portal → Entra ID → App Registrations → Overview
MICROSOFT_TENANT_ID=your-azure-ad-tenant-id-here

# SharePoint Site ID containing the employee database list
# Format: {hostname},{site-collection-guid},{site-guid}
# Example: adb.sharepoint.com,12345678-90ab-cdef-1234-567890abcdef,abcdef12-3456-7890-abcd-ef1234567890
# Get it via Graph API: GET https://graph.microsoft.com/v1.0/sites/{hostname}
SHAREPOINT_SITE_ID=your-sharepoint-site-id-here

# SharePoint List ID (GUID) containing employee records
# The list must have columns: Title, Email, Category (required)
# Find it: Open List → Settings → List Settings → URL contains List=
SHAREPOINT_LIST_ID=your-sharepoint-list-id-here

# ═══════════════════════════════════════════════════════════════
# OPTIONAL: RATE LIMITING (Upstash Redis)
# Sign up at https://upstash.com for a free Redis database
# ═══════════════════════════════════════════════════════════════
# UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token-here

# ═══════════════════════════════════════════════════════════════
# OPTIONAL: ERROR MONITORING (Sentry)
# Sign up at https://sentry.io for error tracking
# ═══════════════════════════════════════════════════════════════
# NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id
