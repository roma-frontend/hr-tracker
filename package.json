{
  "name": "office",
  "version": "0.1.0",
  "private": true,
  "browserslist": [
    "Chrome >= 120",
    "Firefox >= 120",
    "Safari >= 17",
    "Edge >= 120"
  ],
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "scripts": {
    "dev": "next dev --turbo",
    "dev:webpack": "next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "lint:strict": "eslint --max-warnings 0",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "perf": "npm run build && npm run start",
    "test:delete-employees": "tsx scripts/delete-test-employees.ts",
    "test:add-org": "tsx scripts/add-test-org-data.ts",
    "stripe:view": "tsx scripts/view-stripe-transactions.ts",
    "stripe:add-test-data": "tsx scripts/add-test-stripe-data.ts",
    "stripe:export": "tsx scripts/export-stripe-to-excel.ts",
    "stripe:export-pdf": "tsx scripts/export-stripe-to-pdf.ts",
    "stripe:growth-chart": "tsx scripts/stripe-growth-chart.ts",
    "stripe:sync": "tsx scripts/sync-stripe-data.ts",
    "stripe:check-trials": "tsx scripts/check-trial-reminders.ts",
    "prepare": "husky",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:perf": "k6 run tests/performance/load-test.js",
    "test:all": "npm run lint && npm run type-check && npm run test:coverage && npm run test:e2e"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.34",
